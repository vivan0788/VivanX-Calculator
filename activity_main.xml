<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvBranding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VIVANX CALCULATOR"
        android:textColor="#00FFD1"
        android:layout_gravity="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        android:letterSpacing="0.1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#555555"
            android:textSize="22sp"
            android:gravity="end"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:id="@+id/tvMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="55sp"
            android:gravity="end"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="3"
                android:text="C"
                android:background="@drawable/neon_operator"
                android:onClick="onClearClick"
                android:textColor="#FF007F"
                android:textSize="22sp"
                android:layout_margin="3dp"/>
            <Button
                android:id="@+id/btnDivide"
                android:layout_width="85dp"
                android:layout_height="72dp"
                android:text="÷"
                android:background="@drawable/neon_operator"
                android:onClick="onOperatorClick"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:layout_margin="3dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="7" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="8" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="9" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="85dp" android:layout_height="72dp" android:text="*" android:background="@drawable/neon_operator" android:onClick="onOperatorClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="4" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="5" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="6" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="85dp" android:layout_height="72dp" android:text="-" android:background="@drawable/neon_operator" android:onClick="onOperatorClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="1" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="2" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:text="3" android:background="@drawable/neon_btn" android:onClick="onNumberClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
            <Button android:layout_width="85dp" android:layout_height="72dp" android:text="+" android:background="@drawable/neon_operator" android:onClick="onOperatorClick" android:textColor="#FFFFFF" android:layout_margin="3dp" android:textSize="22sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button
                android:id="@+id/btn0"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="2"
                android:text="0"
                android:background="@drawable/neon_btn"
                android:onClick="onNumberClick"
                android:textColor="#FFFFFF"
                android:layout_margin="3dp"
                android:textSize="22sp"/>
            <Button
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="."
                android:background="@drawable/neon_btn"
                android:onClick="onNumberClick"
                android:textColor="#FFFFFF"
                android:layout_margin="3dp"
                android:textSize="22sp"/>
            <Button
                android:id="@+id/btnEqual"
                android:layout_width="85dp"
                android:layout_height="72dp"
                android:text="="
                android:background="@drawable/neon_operator"
                android:onClick="onEqualClick"
                android:textColor="#FFFFFF"
                android:layout_margin="3dp"
                android:textSize="22sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
